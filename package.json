{
  "name": "tractionpal",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config frontend/vite.config.ts",
    "build": "vite build --config frontend/vite.config.ts",
    "preview": "vite preview --config frontend/vite.config.ts",
    "lint": "tsc -p frontend/tsconfig.json --noEmit",
    "test": "jest --passWithNoTests"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "setupFilesAfterEnv": [
      "./frontend/jest.setup.ts"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "diagnostics": {
            "ignoreCodes": [
              151001
            ]
          },
          "astTransformers": {
            "before": [
              {
                "path": "ts-jest-mock-import-meta",
                "options": {
                  "metaObjectReplacement": {
                    "env": {
                      "VITE_API_URL": "https://b9k6o4rtgb.execute-api.us-east-1.amazonaws.com/prod/api/bedrock"
                    }
                  }
                }
              }
            ]
          }
        }
      ]
    }
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.750.0",
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/s3-request-presigner": "^3.750.0",
    "@tailwindcss/vite": "^4.2.1",
    "animejs": "^3.2.2",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "aws-cdk": "^2.1108.0",
    "aws-cdk-lib": "^2.241.0",
    "constructs": "^10.5.1",
    "fast-check": "^4.5.3",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-jest-mock-import-meta": "^1.3.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
